'--- components ---\n'.println();

for (cmp in Component.all) {
  cmp.name.println('---\nComponent: ');
  for (pin in cmp.pins) {
    pin.net.println('Connected on pin ' + pin.name + ': ');
  }

  cmp.isConnectedTo(Net.all.selectOne(n|n.name = '10V'))
     .println('Connected to 10V: ');

  cmp.features.println('Features: ');
}

'\n--- nets ---\n'.println();

for (net in Net.all) {
  net.name.println('---\nNet: ');
  net.pins.println('Connected pins: ');
}
