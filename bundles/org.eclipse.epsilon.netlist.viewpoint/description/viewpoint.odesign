<?xml version="1.0" encoding="UTF-8"?>
<description:Group xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:description="http://www.eclipse.org/sirius/description/1.1.0" xmlns:description_1="http://www.eclipse.org/sirius/diagram/description/1.1.0" xmlns:description_2="http://www.eclipse.org/sirius/tree/description/1.0.0" xmlns:style="http://www.eclipse.org/sirius/diagram/description/style/1.1.0" name="viewpoint" version="15.4.0.202401051836">
  <ownedViewpoints name="org.eclipse.epsilon.netlist.viewpoint" label="Netlist Viewpoint" modelFileExtension="dat">
    <ownedRepresentations xsi:type="description_1:DiagramDescription" name="org.eclipse.epsilon.netlist.viewpoint.diagram" label="Netlist Diagram" domainClass="concise::Netlist" enablePopupBars="true">
      <metamodel href="../../org.eclipse.epsilon.netlist.model.concise/model/netlist.ecore#/"/>
      <layout xsi:type="description_1:CustomLayoutConfiguration" id="org.eclipse.elk.graphviz.dot" label="Graphviz Dot" description="Layered drawings of directed graphs. The algorithm aims edges in the same direction (top to bottom, or left to right) and then attempts to avoid edge crossings and reduce edge length. Edges are routed as spline curves and are thus drawn very smoothly. This algorithm is very suitable for state machine and activity diagrams, where the direction of edges has an important role."/>
      <defaultLayer name="Default">
        <nodeMappings name="org.eclipse.epsilon.netlist.viewpoint.diagram.net" label="Net Node" semanticCandidatesExpression="feature:nets" domainClass="concise::Net">
          <style xsi:type="style:SquareDescription" labelSize="12" showIcon="false" labelPosition="node" resizeKind="NSEW" width="-1" height="-1" color="//@userColorsPalettes[name='Element%20Palette']/@entries[name='net_color']">
            <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
            <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
          </style>
        </nodeMappings>
        <nodeMappings name="org.eclipse.epsilon.netlist.viewpoint.diagram.component" label="Component Node" semanticCandidatesExpression="feature:components" domainClass="concise::Component">
          <borderedNodeMappings name="org.eclipse.epsilon.netlist.viewpoint.diagram.pin" label="Pin Border Node" semanticCandidatesExpression="feature:pins" domainClass="concise::Pin">
            <style xsi:type="style:SquareDescription" labelSize="12" showIcon="false" sizeComputationExpression="2" labelPosition="node" resizeKind="NSEW" width="4" height="2" color="//@userColorsPalettes[name='Element%20Palette']/@entries[name='pin_color']">
              <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
              <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
            </style>
          </borderedNodeMappings>
          <style xsi:type="style:SquareDescription" labelSize="12" showIcon="false" labelPosition="node" resizeKind="NSEW" width="10" height="4" color="//@userColorsPalettes[name='Element%20Palette']/@entries[name='component_color']">
            <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
            <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
          </style>
        </nodeMappings>
        <edgeMappings name="org.eclipse.epsilon.netlist.viewpoint.diagram.pinToNet" label="Pin-Net Edge" sourceMapping="//@ownedViewpoints[name='org.eclipse.epsilon.netlist.viewpoint']/@ownedRepresentations[name='org.eclipse.epsilon.netlist.viewpoint.diagram']/@defaultLayer/@nodeMappings[name='org.eclipse.epsilon.netlist.viewpoint.diagram.component']/@borderedNodeMappings[name='org.eclipse.epsilon.netlist.viewpoint.diagram.pin']" targetMapping="//@ownedViewpoints[name='org.eclipse.epsilon.netlist.viewpoint']/@ownedRepresentations[name='org.eclipse.epsilon.netlist.viewpoint.diagram']/@defaultLayer/@nodeMappings[name='org.eclipse.epsilon.netlist.viewpoint.diagram.net']" targetFinderExpression="feature:net">
          <style targetArrow="NoDecoration" sizeComputationExpression="2">
            <strokeColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='gray']"/>
            <centerLabelStyleDescription labelSize="12">
              <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
            </centerLabelStyleDescription>
          </style>
        </edgeMappings>
      </defaultLayer>
    </ownedRepresentations>
    <ownedRepresentations xsi:type="description_1:DiagramDescription" name="org.eclipse.epsilon.netlist.viewpoint.net.diagram" label="Net Diagram" domainClass="concise::Net" enablePopupBars="true">
      <metamodel href="../../org.eclipse.epsilon.netlist.model.concise/model/netlist.ecore#/"/>
      <layout xsi:type="description_1:CustomLayoutConfiguration" id="org.eclipse.elk.graphviz.dot" label="Graphviz Dot" description="Layered drawings of directed graphs. The algorithm aims edges in the same direction (top to bottom, or left to right) and then attempts to avoid edge crossings and reduce edge length. Edges are routed as spline curves and are thus drawn very smoothly. This algorithm is very suitable for state machine and activity diagrams, where the direction of edges has an important role.">
        <layoutOptions xsi:type="description_1:BooleanLayoutOption" id="org.eclipse.elk.graphviz.concentrate" value="true">
          <targets>PARENT</targets>
        </layoutOptions>
        <layoutOptions xsi:type="description_1:EnumLayoutOption" id="org.eclipse.elk.edgeRouting">
          <targets>PARENT</targets>
          <value name="ORTHOGONAL"/>
        </layoutOptions>
        <layoutOptions xsi:type="description_1:DoubleLayoutOption" id="org.eclipse.elk.spacing.nodeNode" value="40.0">
          <targets>PARENT</targets>
        </layoutOptions>
      </layout>
      <defaultLayer name="Default">
        <nodeMappings name="org.eclipse.epsilon.netlist.viewpoint.netdiagram.net" label="Net Node" semanticCandidatesExpression="var:self" domainClass="concise::Net">
          <style xsi:type="style:SquareDescription" labelSize="12" showIcon="false" sizeComputationExpression="4" labelPosition="node" resizeKind="NSEW" width="-1" height="-1" color="//@userColorsPalettes[name='Element%20Palette']/@entries[name='net_color']">
            <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
            <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
          </style>
        </nodeMappings>
        <nodeMappings name="org.eclipse.epsilon.netlist.viewpoint.netdiagram.component" label="Component Node" semanticCandidatesExpression="aql:self.pins.component" domainClass="concise::Component">
          <borderedNodeMappings name="org.eclipse.epsilon.netlist.viewpoint.netdiagram.pin" label="Pin Border Node" semanticCandidatesExpression="aql:self.pins->intersection(diagram.nodes.semanticElements->select(e|e.oclIsKindOf(concise::Net))->first().pins)" domainClass="concise::Pin">
            <style xsi:type="style:SquareDescription" labelSize="12" showIcon="false" sizeComputationExpression="2" labelPosition="node" resizeKind="NSEW" width="4" height="2" color="//@userColorsPalettes[name='Element%20Palette']/@entries[name='pin_color']">
              <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
              <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
            </style>
          </borderedNodeMappings>
          <style xsi:type="style:SquareDescription" labelSize="12" showIcon="false" sizeComputationExpression="4" labelPosition="node" resizeKind="NSEW" width="-1" height="-1" color="//@userColorsPalettes[name='Element%20Palette']/@entries[name='component_color']">
            <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
            <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
          </style>
        </nodeMappings>
        <edgeMappings name="org.eclipse.epsilon.netlist.viewpoint.netdiagram.netToPin" label="Net to Pin edge" sourceMapping="//@ownedViewpoints[name='org.eclipse.epsilon.netlist.viewpoint']/@ownedRepresentations[name='org.eclipse.epsilon.netlist.viewpoint.net.diagram']/@defaultLayer/@nodeMappings[name='org.eclipse.epsilon.netlist.viewpoint.netdiagram.net']" targetMapping="//@ownedViewpoints[name='org.eclipse.epsilon.netlist.viewpoint']/@ownedRepresentations[name='org.eclipse.epsilon.netlist.viewpoint.net.diagram']/@defaultLayer/@nodeMappings[name='org.eclipse.epsilon.netlist.viewpoint.netdiagram.component']/@borderedNodeMappings[name='org.eclipse.epsilon.netlist.viewpoint.netdiagram.pin']" targetFinderExpression="feature:pins">
          <style sizeComputationExpression="2">
            <strokeColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='gray']"/>
            <centerLabelStyleDescription labelSize="12">
              <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
            </centerLabelStyleDescription>
          </style>
        </edgeMappings>
      </defaultLayer>
    </ownedRepresentations>
    <ownedRepresentations xsi:type="description_1:DiagramDescription" name="org.eclipse.epsilon.netlist.viewpoint.component.diagram" label="Component Diagram" domainClass="concise::Component" enablePopupBars="true">
      <metamodel href="../../org.eclipse.epsilon.netlist.model.concise/model/netlist.ecore#/"/>
      <layout xsi:type="description_1:CustomLayoutConfiguration" id="org.eclipse.elk.graphviz.neato" label="Graphviz Neato" description="Spring model layouts. Neato attempts to minimize a global energy function, which is equivalent to statistical multi-dimensional scaling. The solution is achieved using stress majorization, though the older Kamada-Kawai algorithm, using steepest descent, is also available.">
        <layoutOptions xsi:type="description_1:EnumLayoutOption" id="org.eclipse.elk.edgeRouting">
          <targets>PARENT</targets>
          <value name="ORTHOGONAL"/>
        </layoutOptions>
      </layout>
      <defaultLayer name="Default">
        <nodeMappings name="org.eclipse.epsilon.netlist.viewpoint.cmpdiagram.component" label="Component Node" semanticCandidatesExpression="var:self" domainClass="concise::Component">
          <borderedNodeMappings name="org.eclipse.epsilon.netlist.viewpoint.cmpdiagram.pin" label="Pin Border Node" semanticCandidatesExpression="feature:pins" domainClass="concise::Pin">
            <style xsi:type="style:SquareDescription" labelSize="12" showIcon="false" sizeComputationExpression="2" labelPosition="node" resizeKind="NSEW" width="4" height="2" color="//@userColorsPalettes[name='Element%20Palette']/@entries[name='pin_color']">
              <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
              <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
            </style>
          </borderedNodeMappings>
          <style xsi:type="style:SquareDescription" labelSize="12" showIcon="false" sizeComputationExpression="aql:self.pins->size()" labelPosition="node" resizeKind="NSEW" width="-1" height="-1" color="//@userColorsPalettes[name='Element%20Palette']/@entries[name='component_color']">
            <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
            <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
          </style>
        </nodeMappings>
        <nodeMappings name="org.eclipse.epsilon.netlist.viewpoint.netdiagram.net" label="Net Node" semanticCandidatesExpression="aql:self.pins.net" domainClass="concise::Net">
          <style xsi:type="style:SquareDescription" labelSize="12" showIcon="false" labelPosition="node" resizeKind="NSEW" width="-1" height="-1" color="//@userColorsPalettes[name='Element%20Palette']/@entries[name='net_color']">
            <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
            <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
          </style>
        </nodeMappings>
        <edgeMappings name="org.eclipse.epsilon.netlist.viewpoint.cmpdiagram.netToPin" label="Net to Pin edge" sourceMapping="//@ownedViewpoints[name='org.eclipse.epsilon.netlist.viewpoint']/@ownedRepresentations[name='org.eclipse.epsilon.netlist.viewpoint.component.diagram']/@defaultLayer/@nodeMappings[name='org.eclipse.epsilon.netlist.viewpoint.netdiagram.net']" targetMapping="//@ownedViewpoints[name='org.eclipse.epsilon.netlist.viewpoint']/@ownedRepresentations[name='org.eclipse.epsilon.netlist.viewpoint.component.diagram']/@defaultLayer/@nodeMappings[name='org.eclipse.epsilon.netlist.viewpoint.cmpdiagram.component']/@borderedNodeMappings[name='org.eclipse.epsilon.netlist.viewpoint.cmpdiagram.pin']" targetFinderExpression="feature:pins">
          <style sizeComputationExpression="2">
            <strokeColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='gray']"/>
            <centerLabelStyleDescription labelSize="12">
              <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
            </centerLabelStyleDescription>
          </style>
        </edgeMappings>
      </defaultLayer>
    </ownedRepresentations>
    <ownedRepresentations xsi:type="description_2:TreeDescription" name="org.eclipse.epsilon.netlist.viewpoint.tree.diagram" label="Tree Representation" domainClass="concise::Netlist">
      <metamodel href="../../org.eclipse.epsilon.netlist.model.concise/model/netlist.ecore#/"/>
      <subItemMappings name="org.eclipse.epsilon.netlist.viewpoint.tree.namedNets" label="Named Nets Node" domainClass="concise::Netlist" semanticCandidatesExpression="var:self">
        <defaultStyle labelSize="12" labelExpression="aql:'Named Nets'">
          <labelFormat>bold</labelFormat>
          <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
          <backgroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='white']"/>
        </defaultStyle>
        <subItemMappings name="org.eclipse.epsilon.netlist.viewpoint.tree.namedNet" label="Named Net Node" domainClass="concise::Net" semanticCandidatesExpression="aql:self.nets->select(n | not n.name.startsWith('UNNAMED_'))">
          <defaultStyle labelSize="12" labelExpression="aql:'Net ' + self.name">
            <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
            <backgroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='white']"/>
          </defaultStyle>
          <subItemMappings name="org.eclipse.epsilon.netlist.viewpoint.tree.namedNetPin" label="Named Net Pin Node" domainClass="concise::Pin" semanticCandidatesExpression="aql:self.pins->sortedBy(p | p.name)">
            <defaultStyle labelSize="12" labelExpression="aql:'Net Pin ' + self.name + ' from ' + self.component.name">
              <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
              <backgroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='white']"/>
            </defaultStyle>
          </subItemMappings>
        </subItemMappings>
      </subItemMappings>
      <subItemMappings name="org.eclipse.epsilon.netlist.viewpoint.tree.unnamedNets" label="Unnamed Nets Node" domainClass="concise::Netlist" semanticCandidatesExpression="var:self">
        <defaultStyle labelSize="12" labelExpression="aql:'Unnamed Nets'">
          <labelFormat>bold</labelFormat>
          <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
          <backgroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='white']"/>
        </defaultStyle>
        <subItemMappings name="org.eclipse.epsilon.netlist.viewpoint.tree.unnamedNet" label="Unnamed Net Node" domainClass="concise::Net" semanticCandidatesExpression="aql:self.nets->select(n | n.name.startsWith('UNNAMED_'))">
          <defaultStyle labelSize="12" labelExpression="aql:'Net ' + self.name">
            <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
            <backgroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='white']"/>
          </defaultStyle>
          <subItemMappings name="org.eclipse.epsilon.netlist.viewpoint.tree.unnamedNetPin" label="Unnamed Net Pin Node" domainClass="concise::Pin" semanticCandidatesExpression="aql:self.pins->sortedBy(p | p.name)">
            <defaultStyle labelSize="12" labelExpression="aql:'Net Pin ' + self.name + ' from ' + self.component.name">
              <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
              <backgroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='white']"/>
            </defaultStyle>
          </subItemMappings>
        </subItemMappings>
      </subItemMappings>
      <subItemMappings name="org.eclipse.epsilon.netlist.viewpoint.tree.components" label="Components Node" domainClass="concise::Netlist" semanticCandidatesExpression="var:self">
        <defaultStyle labelSize="12" labelExpression="aql:'Components'">
          <labelFormat>bold</labelFormat>
          <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
          <backgroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='white']"/>
        </defaultStyle>
        <subItemMappings name="org.eclipse.epsilon.netlist.viewpoint.tree.components" label="Component Node" domainClass="concise::Component" semanticCandidatesExpression="feature:components">
          <defaultStyle labelSize="12" labelExpression="aql:'Component ' + self.name + ' (' + self.features->sep(', ') + ')'">
            <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
            <backgroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='white']"/>
          </defaultStyle>
          <subItemMappings name="org.eclipse.epsilon.netlist.viewpoint.tree.componentPin" label="Component Pin Node" domainClass="concise::Pin" semanticCandidatesExpression="aql:self.pins->sortedBy(p | p.name)">
            <defaultStyle labelSize="12" labelExpression="aql:'Component Pin ' + self.name + ' to ' + self.net.name">
              <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
              <backgroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='white']"/>
            </defaultStyle>
            <subItemMappings name="org.eclipse.epsilon.netlist.viewpoint.tree.sameNetPin" label="Same Net Pin Node" domainClass="concise::Pin" semanticCandidatesExpression="aql:self.net.pins->excluding(self)">
              <defaultStyle labelSize="12" labelExpression="aql:'Same Net: Pin ' + self.name + ' from ' + self.component.name">
                <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
                <backgroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='white']"/>
              </defaultStyle>
            </subItemMappings>
          </subItemMappings>
        </subItemMappings>
      </subItemMappings>
    </ownedRepresentations>
    <ownedRepresentations xsi:type="description_1:DiagramDescription" name="org.eclipse.epsilon.netlist.viewpoint.block.diagram" label="Circuit Block Instance Diagram" domainClass="blocknet::CircuitBlockInstance" enablePopupBars="true">
      <metamodel href="../../org.eclipse.epsilon.netlist.model.blocknet/model/blocknet.ecore#/"/>
      <layout xsi:type="description_1:CustomLayoutConfiguration" id="org.eclipse.elk.graphviz.fdp" label="Graphviz FDP" description="Spring model layouts similar to those of Neato, but does this by reducing forces rather than working with energy. Fdp implements the Fruchterman-Reingold heuristic including a multigrid solver that handles larger graphs and clustered undirected graphs."/>
      <defaultLayer name="Default">
        <nodeMappings name="org.eclipse.epsilon.netlist.viewpoint.block.diagram.component" label="Circuit Block Component" semanticCandidatesExpression="feature:components" domainClass="blocknet::Component">
          <borderedNodeMappings name="org.eclipse.epsilon.netlist.viewpoint.block.diagram.component.pin" label="Block Component Pin" semanticCandidatesExpression="feature:pins" domainClass="blocknet::Pin">
            <style xsi:type="style:SquareDescription" labelSize="12" showIcon="false" labelPosition="node" resizeKind="NSEW">
              <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
              <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
              <color xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='white']"/>
            </style>
          </borderedNodeMappings>
          <style xsi:type="style:SquareDescription" labelSize="12" showIcon="false" labelExpression="feature:circuitName" sizeComputationExpression="aql:self.pins->size()" labelPosition="node" resizeKind="NSEW" width="-1" height="-1">
            <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
            <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
            <color xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='green']"/>
          </style>
        </nodeMappings>
        <nodeMappings name="org.eclipse.epsilon.netlist.viewpoint.block.diagram.namedNet" label="Named Net Node" semanticCandidatesExpression="aql:self.components.pins.net->select(n | not n.name.startsWith('UNNAMED_'))" domainClass="blocknet::Net">
          <style xsi:type="style:SquareDescription" labelSize="12" showIcon="false" labelExpression="aql:if self.name.startsWith('UNNAMED_') then '' else self.name endif" sizeComputationExpression="1" labelPosition="node" resizeKind="NSEW" width="-1" height="-1">
            <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
            <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
            <color xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='light_blue']"/>
          </style>
        </nodeMappings>
        <nodeMappings name="org.eclipse.epsilon.netlist.viewpoint.block.diagram.unnamedNet" label="Unnamed Net Node" semanticCandidatesExpression="aql:self.components.pins.net->select(n | n.name.startsWith('UNNAMED_'))" domainClass="blocknet::Net">
          <style xsi:type="style:DotDescription" labelSize="12" showIcon="false" labelExpression="aql:''" sizeComputationExpression="2" labelPosition="node" resizeKind="NSEW">
            <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
            <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
            <backgroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='gray']"/>
          </style>
        </nodeMappings>
        <edgeMappings name="org.eclipse.epsilon.netlist.viewpoint.block.diagram.pin2net" label="Component Pin to Net Edge" sourceMapping="//@ownedViewpoints[name='org.eclipse.epsilon.netlist.viewpoint']/@ownedRepresentations[name='org.eclipse.epsilon.netlist.viewpoint.block.diagram']/@defaultLayer/@nodeMappings[name='org.eclipse.epsilon.netlist.viewpoint.block.diagram.component']/@borderedNodeMappings[name='org.eclipse.epsilon.netlist.viewpoint.block.diagram.component.pin']" targetMapping="//@ownedViewpoints[name='org.eclipse.epsilon.netlist.viewpoint']/@ownedRepresentations[name='org.eclipse.epsilon.netlist.viewpoint.block.diagram']/@defaultLayer/@nodeMappings[name='org.eclipse.epsilon.netlist.viewpoint.block.diagram.namedNet'] //@ownedViewpoints[name='org.eclipse.epsilon.netlist.viewpoint']/@ownedRepresentations[name='org.eclipse.epsilon.netlist.viewpoint.block.diagram']/@defaultLayer/@nodeMappings[name='org.eclipse.epsilon.netlist.viewpoint.block.diagram.unnamedNet']" targetFinderExpression="feature:net">
          <style targetArrow="NoDecoration" sizeComputationExpression="2" routingStyle="manhattan" foldingStyle="TARGET">
            <strokeColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='gray']"/>
            <centerLabelStyleDescription labelSize="12">
              <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
            </centerLabelStyleDescription>
          </style>
        </edgeMappings>
      </defaultLayer>
    </ownedRepresentations>
    <ownedJavaExtensions qualifiedClassName="org.eclipse.epsilon.netlist.viewpoint.Services"/>
  </ownedViewpoints>
  <userColorsPalettes name="Element Palette">
    <entries xsi:type="description:UserFixedColor" red="86" green="221" blue="255" name="net_color"/>
    <entries xsi:type="description:UserFixedColor" red="184" green="255" blue="180" name="component_color"/>
    <entries xsi:type="description:UserFixedColor" red="255" green="255" blue="255" name="pin_color"/>
  </userColorsPalettes>
</description:Group>
